# Required
DATABASE_URL=postgres://lore:lore@localhost:5433/lore_memory
ADMIN_SECRET=change_me_in_production

# Tests use the same DATABASE_URL (they read process.env.DATABASE_URL).
# If your local Postgres container is on a different port, override when running tests:
#   DATABASE_URL=postgres://lore:lore@localhost:5433/lore_memory pnpm test

# Server
MCP_SERVER_PORT=3100

# Docker Compose (required for docker compose up)
POSTGRES_PASSWORD=change_me_in_production
LORE_PG_VOLUME_BYTES=10737418240    # 10 GB stub; set to volume capacity for accurate disk alerting

# Embedding provider — pick one:
#
#   openai (default): requires OPENAI_API_KEY, vector dims = 1536
#   local:            uses Ollama + nomic-embed-text, vector dims = 768
#                     start Ollama with: docker compose --profile local-embedding up -d
#                     pull model once:   docker compose --profile local-embedding exec ollama ollama pull nomic-embed-text
#                     after changing provider: pnpm drizzle-kit generate && pnpm drizzle-kit migrate
#
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...               # required when EMBEDDING_PROVIDER=openai; leave empty → /health reports unreachable
OLLAMA_BASE_URL=http://ollama:11434 # required when EMBEDDING_PROVIDER=local; default shown

# Web UI
NEXT_PUBLIC_LORE_API_URL=http://localhost:3100
WEB_UI_SECRET=change_me_in_production

# Optional
PROPAGATION_ENABLED=true
PROPAGATION_INTERVAL_MS=3600000
LOG_LEVEL=info
MAX_EMBEDDING_BATCH_SIZE=100
SIMILARITY_THRESHOLD=0.90
