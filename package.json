{
  "name": "lore-memory-mcp",
  "version": "1.0.0",
  "description": "Lore memory server — institutional memory layer for BMAD-driven development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lore": "dist/cli/index.js"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "docker:build": "docker compose build mcp-server",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f mcp-server",
    "benchmark:seed": "tsx scripts/benchmark/seed.ts",
    "benchmark:run": "tsx scripts/benchmark/run-benchmarks.ts",
    "benchmark:all": "tsx scripts/benchmark/seed.ts && tsx scripts/benchmark/run-benchmarks.ts",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "[ -d .git ] && husky || true",
    "publish:cli": "node scripts/publish-cli.mjs"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "@inquirer/checkbox": "^5.1.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^5.1.1",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.43.1",
    "fastify": "^4.29.1",
    "handlebars": "^4.7.9",
    "openai": "^6.37.0",
    "pg": "^8.15.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "semver": "^7.8.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxlint": "^0.16.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "oxlint",
      "prettier --check"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --check"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
