# Required
DATABASE_URL=postgres://lore:lore@localhost:5432/lore_memory
ADMIN_SECRET=change_me_in_production

# Server
MCP_SERVER_PORT=3100

# Docker Compose (required for docker compose up)
POSTGRES_PASSWORD=change_me_in_production
OPENAI_API_KEY=sk-...               # leave empty → /health reports openai: "unknown"
LORE_PG_VOLUME_BYTES=10737418240    # 10 GB stub; set to volume capacity for accurate disk alerting

# Optional
PROPAGATION_ENABLED=true
PROPAGATION_INTERVAL_MS=3600000
LOG_LEVEL=info
MAX_EMBEDDING_BATCH_SIZE=100
SIMILARITY_THRESHOLD=0.90

# Version label for /health and /metrics
LORE_VERSION=1.0.0
