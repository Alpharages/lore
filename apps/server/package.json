{
  "name": "@lore/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "lint": "oxlint src/",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "benchmark:seed": "tsx scripts/benchmark/seed.ts",
    "benchmark:run": "tsx scripts/benchmark/run-benchmarks.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "openai": "^6.37.0",
    "pg": "^8.15.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^0.16.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "oxlint",
      "prettier --check"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --check"
    ]
  }
}
