# =====================================================================
# @lore/server — environment variables
# =====================================================================
# Copy this file to apps/server/.env and fill in real values.
# Loaded by `dotenv/config` when `pnpm --filter @lore/server dev`
# (or any script that runs from apps/server/) starts the process.
# Also referenced by docker-compose.yml as the env_file for both
# the postgres and mcp-server services.
# =====================================================================

# --- Database --------------------------------------------------------
DATABASE_URL=postgres://lore:lore@localhost:5433/lore_memory

# Tests read the same DATABASE_URL. If your local Postgres is on a
# different port/db, override per-command:
#   DATABASE_URL=postgres://lore:lore@localhost:5433/lore_memory pnpm test

# --- Auth ------------------------------------------------------------
ADMIN_SECRET=change_me_in_production

# --- Server runtime --------------------------------------------------
MCP_SERVER_PORT=3100
LOG_LEVEL=info

# --- CORS ------------------------------------------------------------
# Origin(s) allowed to call this API directly (comma-separated). When unset,
# CORS is disabled (same-origin only). Production should list the deployed
# web UI origin, e.g. "https://lore.example.com".
# WEB_UI_ORIGIN=http://localhost:3001

# --- Docker / Postgres image -----------------------------------------
# Consumed by the pgvector image to initialize the database password.
POSTGRES_PASSWORD=change_me_in_production
# 10 GB stub; set to volume capacity for accurate disk alerting.
LORE_PG_VOLUME_BYTES=10737418240

# --- Embedding provider ----------------------------------------------
#   openai (default): requires OPENAI_API_KEY, vector dims = 1536
#   local:            uses Ollama + nomic-embed-text, vector dims = 768
#                     start Ollama with:
#                       docker compose --profile local-embedding up -d
#                     pull model once:
#                       docker compose --profile local-embedding exec ollama \
#                         ollama pull nomic-embed-text
#                     after switching providers:
#                       pnpm drizzle-kit generate && pnpm drizzle-kit migrate
EMBEDDING_PROVIDER=openai
# Required when EMBEDDING_PROVIDER=openai (else /health reports unreachable).
OPENAI_API_KEY=sk-...
# Required when EMBEDDING_PROVIDER=local.
OLLAMA_BASE_URL=http://ollama:11434
MAX_EMBEDDING_BATCH_SIZE=100
SIMILARITY_THRESHOLD=0.85

# --- Propagation -----------------------------------------------------
PROPAGATION_ENABLED=true
PROPAGATION_INTERVAL_MS=3600000
