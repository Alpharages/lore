{
  "info": {
    "name": "Lore Platform API",
    "description": "REST API for the Lore Platform — lesson memory, session management, and project administration.\n\n**Authentication**\n- Project endpoints: `Authorization: Bearer {{projectApiKey}}` (format: `lore_<slug>_<24chars>`)\n- Admin endpoints: `X-Admin-Secret: {{adminSecret}}`\n- Public endpoints: no auth required",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "lore-platform-api-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "description": "Base URL of the Lore API server"
    },
    {
      "key": "projectApiKey",
      "value": "lore_<slug>_<24chars>",
      "description": "Project API key — format: lore_<project-slug>_<24-char-secret>"
    },
    {
      "key": "adminSecret",
      "value": "",
      "description": "Value of the ADMIN_SECRET environment variable"
    },
    {
      "key": "projectSlug",
      "value": "my-project",
      "description": "Project slug used in path params"
    },
    {
      "key": "propagationId",
      "value": "00000000-0000-0000-0000-000000000000",
      "description": "UUID of a pending propagation"
    },
    {
      "key": "sessionId",
      "value": "00000000-0000-0000-0000-000000000000",
      "description": "UUID of an active session"
    },
    {
      "key": "lessonId",
      "value": "00000000-0000-0000-0000-000000000000",
      "description": "UUID of a lesson"
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns server health status. No authentication required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\"status\":\"ok\"}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin — Projects",
      "description": "Project management endpoints. Require `X-Admin-Secret` header.",
      "item": [
        {
          "name": "Register Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Admin-Secret", "value": "{{adminSecret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Project\",\n  \"slug\": \"my-project\",\n  \"stack_tags\": [\"typescript\", \"fastify\", \"postgres\"],\n  \"repos\": [\n    {\n      \"slug\": \"my-repo\",\n      \"stack_tags\": [\"typescript\"]\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "register"]
            },
            "description": "Register a new project and generate its API key.\n\nRequired fields: `name`, `slug` (pattern: `^[a-z0-9-]{2,40}$`)."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"uuid\",\n  \"slug\": \"my-project\",\n  \"name\": \"My Project\",\n  \"apiKey\": \"lore_my-project_XXXXXXXXXXXXXXXXXXXXXXXX\"\n}"
            }
          ]
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Secret", "value": "{{adminSecret}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"]
            },
            "description": "List all registered projects."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": \"uuid\",\n    \"slug\": \"my-project\",\n    \"name\": \"My Project\",\n    \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Admin-Secret", "value": "{{adminSecret}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectSlug}}"]
            },
            "description": "Delete a project by slug."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\"deleted\":true}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin — Metrics",
      "description": "Prometheus-compatible metrics endpoint. Requires `X-Admin-Secret`.",
      "item": [
        {
          "name": "Get Metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Admin-Secret", "value": "{{adminSecret}}" }],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["metrics"]
            },
            "description": "Returns Prometheus-format metrics for the server."
          }
        }
      ]
    },
    {
      "name": "Inbox",
      "description": "Inbox and lesson propagation management. Require `Authorization: Bearer {{projectApiKey}}`.",
      "item": [
        {
          "name": "Get Project Inbox",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{projectApiKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectSlug}}/inbox",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectSlug}}", "inbox"]
            },
            "description": "Get pending propagation suggestions for the project's inbox."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"propagations\": [\n    {\n      \"id\": \"uuid\",\n      \"lessonTitle\": \"Example lesson\",\n      \"sourceProject\": \"other-project\",\n      \"createdAt\": \"2024-01-01T00:00:00.000Z\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Accept Propagation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{projectApiKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/propagations/{{propagationId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "propagations", "{{propagationId}}", "accept"]
            },
            "description": "Accept a pending propagation suggestion — copies the lesson into this project."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\"accepted\":true}"
            }
          ]
        },
        {
          "name": "Reject Propagation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{projectApiKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/propagations/{{propagationId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "propagations", "{{propagationId}}", "reject"]
            },
            "description": "Reject a pending propagation suggestion."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\"rejected\":true}"
            }
          ]
        }
      ]
    },
    {
      "name": "MCP Tools",
      "description": "Lore memory tool endpoints exposed as REST. All require `Authorization: Bearer {{projectApiKey}}`.",
      "item": [
        {
          "name": "Whoami",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{projectApiKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/mcp/whoami",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "whoami"]
            },
            "description": "Returns the authenticated project identity."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"project\": {\n    \"id\": \"uuid\",\n    \"slug\": \"my-project\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Save Lesson",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Always validate UUID format before DB insert\",\n  \"problem\": \"Passing a malformed UUID to Drizzle causes a Postgres cast error at runtime.\",\n  \"root_cause\": \"No format validation before the repository call.\",\n  \"fix\": \"Added zod UUID validation in the service layer before calling the repository.\",\n  \"prevention_rule\": \"Validate all UUID inputs with zod `z.string().uuid()` at the service boundary.\",\n  \"stack_tags\": [\"typescript\", \"drizzle\", \"postgres\"],\n  \"category\": \"data-validation\",\n  \"severity\": \"high\",\n  \"repo_slug\": \"my-repo\",\n  \"session_id\": \"{{sessionId}}\",\n  \"user_handle\": \"khakan.ali\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/save_lesson",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "save_lesson"]
            },
            "description": "Save a new lesson. If a semantically similar lesson already exists, its occurrence count is incremented instead.\n\nRequired: `title`, `problem`, `fix`, `prevention_rule`."
          }
        },
        {
          "name": "Increment Occurrence",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lesson_id\": \"{{lessonId}}\",\n  \"user_handle\": \"khakan.ali\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/increment_occurrence",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "increment_occurrence"]
            },
            "description": "Increment the occurrence counter of an existing lesson by its UUID.\n\nRequired: `lesson_id` (UUID)."
          }
        },
        {
          "name": "Query Lessons",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stack_tags\": [\"typescript\", \"postgres\"],\n  \"category\": \"data-validation\",\n  \"severity\": \"high\",\n  \"last_n_days\": 30,\n  \"repo_slug\": \"my-repo\",\n  \"limit\": 5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/query_lessons",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "query_lessons"]
            },
            "description": "Query lessons with optional filters. All fields are optional.\n\n`severity` enum: `critical` | `high` | `medium` | `low`\n`limit` range: 1–20 (default 5)."
          }
        },
        {
          "name": "Search Similar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"UUID validation drizzle postgres type error\",\n  \"threshold\": 0.7,\n  \"limit\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/search_similar",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "search_similar"]
            },
            "description": "Semantic search for lessons similar to the provided text.\n\nRequired: `text`.\n`threshold` range: 0–1 (default 0.7). `limit` default 3."
          }
        },
        {
          "name": "Start Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repo_slug\": \"my-repo\",\n  \"branch\": \"feature/my-branch\",\n  \"task_summary\": \"Implementing lesson query endpoint\",\n  \"user_handle\": \"khakan.ali\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/start_session",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "start_session"]
            },
            "description": "Start a new work session.\n\nRequired: `repo_slug`, `branch`."
          }
        },
        {
          "name": "Start Session From Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_task_id\": \"abc123xyz\",\n  \"external_tracker_type\": \"clickup\",\n  \"external_task_ref\": \"https://app.clickup.com/t/abc123xyz\",\n  \"task_summary\": \"Build lesson query REST endpoint\",\n  \"branch\": \"feature/lesson-query\",\n  \"user_handle\": \"khakan.ali\",\n  \"bmad_skill\": \"dev\",\n  \"bmad_workflow\": \"story-implementation\",\n  \"repo_slug\": \"my-repo\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/start_session_from_task",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "start_session_from_task"]
            },
            "description": "Start or resume a session associated with an external tracker task.\n\nRequired: `external_task_id`, `external_tracker_type` (`clickup` | `jira` | `asana`)."
          }
        },
        {
          "name": "End Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{sessionId}}\",\n  \"decisions\": [\n    {\n      \"what\": \"Used zod for UUID validation instead of manual regex\",\n      \"why\": \"Zod provides type inference in addition to runtime validation\"\n    }\n  ],\n  \"lessons_applied\": [\n    \"{{lessonId}}\"\n  ],\n  \"files_touched\": [\n    \"apps/server/src/services/lessons.service.ts\",\n    \"apps/server/src/repositories/lessons.repository.ts\"\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/end_session",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "end_session"]
            },
            "description": "End an active work session and record outcomes.\n\nRequired: `session_id` (UUID).\n`decisions` items require both `what` and `why`."
          }
        },
        {
          "name": "Query Lessons For Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_task_id\": \"abc123xyz\",\n  \"task_context\": {\n    \"title\": \"Build lesson query REST endpoint\",\n    \"description\": \"Expose the lesson query service as a REST endpoint with filtering support.\",\n    \"acceptance_criteria\": \"Endpoint returns filtered lessons with correct pagination.\",\n    \"parent_epic_id\": \"epic-789\",\n    \"stack_tags\": [\"typescript\", \"fastify\"]\n  },\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/query_lessons_for_task",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "query_lessons_for_task"]
            },
            "description": "Query relevant lessons for a specific tracker task using task context for semantic ranking.\n\nRequired: `external_task_id`. `limit` range: 1–20 (default 10)."
          }
        },
        {
          "name": "Link Lessons To Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_task_id\": \"abc123xyz\",\n  \"consulted\": [\n    \"{{lessonId}}\"\n  ],\n  \"applied\": [\n    \"{{lessonId}}\"\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/link_lessons_to_task",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "link_lessons_to_task"]
            },
            "description": "Link consulted and applied lessons to a tracker task for the active session.\n\nRequired: `external_task_id`. Both `consulted` and `applied` are UUID arrays."
          }
        },
        {
          "name": "Get Pending Propagations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/get_pending_propagations",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "get_pending_propagations"]
            },
            "description": "Get pending lesson propagation suggestions for this project. Body must be an empty object `{}`."
          }
        },
        {
          "name": "Accept Propagation (MCP Tool)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propagation_id\": \"{{propagationId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/accept_propagation",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "accept_propagation"]
            },
            "description": "Accept a pending propagation suggestion (MCP tool variant).\n\nRequired: `propagation_id` (UUID)."
          }
        },
        {
          "name": "Reject Propagation (MCP Tool)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propagation_id\": \"{{propagationId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/reject_propagation",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "reject_propagation"]
            },
            "description": "Reject a pending propagation suggestion (MCP tool variant).\n\nRequired: `propagation_id` (UUID)."
          }
        },
        {
          "name": "Capture Review Finding",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_task_id\": \"abc123xyz\",\n  \"external_tracker_type\": \"clickup\",\n  \"external_task_ref\": \"https://app.clickup.com/t/abc123xyz\",\n  \"severity\": \"high\",\n  \"reviewer\": \"khakan.ali\",\n  \"workflow\": \"pr-review\",\n  \"finding\": {\n    \"title\": \"Missing input sanitization in lesson title\",\n    \"problem\": \"Lesson titles are stored without sanitizing HTML entities, enabling XSS in the UI.\",\n    \"root_cause\": \"The service layer does not strip or escape HTML before persisting the title.\",\n    \"fix\": \"Added DOMPurify sanitization in the service before passing data to the repository.\",\n    \"prevention_rule\": \"Always sanitize user-supplied string fields that will be rendered as HTML.\",\n    \"stack_tags\": [\"typescript\", \"security\"],\n    \"category\": \"security\",\n    \"code_pointer\": {\n      \"file\": \"apps/server/src/services/lessons.service.ts\",\n      \"line_start\": 42,\n      \"line_end\": 55\n    }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp/tools/capture_review_finding",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "tools", "capture_review_finding"]
            },
            "description": "Capture a code review finding as a lesson.\n\nRequired: `external_task_id`, `external_tracker_type`, `severity`, `finding`.\n`finding` required fields: `title`, `problem`, `fix`, `prevention_rule`.\n`code_pointer` required fields: `file`, `line_start`, `line_end`."
          }
        }
      ]
    },
    {
      "name": "MCP Protocol",
      "description": "Streamable HTTP MCP protocol endpoint.",
      "item": [
        {
          "name": "MCP Protocol (Streamable HTTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{projectApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/mcp",
              "host": ["{{baseUrl}}"],
              "path": ["mcp"]
            },
            "description": "MCP Streamable HTTP transport entry point. Accepts JSON-RPC 2.0 messages.\nGET /mcp returns 405 (stateless mode not supported)."
          }
        }
      ]
    },
    {
      "name": "Dev Only",
      "description": "Endpoints available only when NODE_ENV != production.",
      "item": [
        {
          "name": "Test — Lesson Count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{projectApiKey}}" }],
            "url": {
              "raw": "{{baseUrl}}/mcp/_test/lesson-count",
              "host": ["{{baseUrl}}"],
              "path": ["mcp", "_test", "lesson-count"]
            },
            "description": "Returns the total lesson count for the authenticated project. Only available when NODE_ENV is not 'production'."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
