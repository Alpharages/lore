# =====================================================================
# @lore/web — environment variables
# =====================================================================
# Copy this file to apps/web/.env (or .env.local) and fill in real
# values. Next.js auto-loads .env / .env.local from apps/web/ when
# `next dev` or `next start` runs from this directory.
# Also referenced by docker-compose.yml as the env_file for the web
# service.
# =====================================================================

# --- API target ------------------------------------------------------
# Browser-visible (must be NEXT_PUBLIC_*) URL of the @lore/server API.
NEXT_PUBLIC_LORE_API_URL=http://localhost:3100

# --- Web auth --------------------------------------------------------
# Shared password used by the /api/auth/login route.
WEB_UI_SECRET=change_me_in_production

# --- Session cookie --------------------------------------------------
# Controls the `Secure` flag on the session cookie. Default is `true`
# (production behind TLS). Set to `false` ONLY for local HTTP dev — a
# `Secure` cookie issued over plain HTTP is silently dropped by browsers
# and breaks login. Next.js standalone forces NODE_ENV=production, so
# we cannot key off NODE_ENV; this must be explicit.
# COOKIE_SECURE=false
